# Production environment. Copy to .env, fill in, and keep OUT of version control.

NODE_ENV=production
PORT=3000

# REQUIRED: long random secret that signs session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Initial CEO password (first boot only). Change immediately after first login.
SEED_CEO_PASSWORD=

# Writable, BACKED-UP path for the SQLite database.
# Docker: leave as /data (a named volume). Bare-metal: e.g. /opt/rootsgoods/data
DATA_DIR=/data
