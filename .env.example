# Copy to .env and set real values before deploying.

# Port the server listens on
PORT=3000

# Set to "production" so auth cookies are marked Secure (requires HTTPS)
NODE_ENV=production

# REQUIRED IN PRODUCTION: long random string used to sign session tokens.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Password for the auto-created CEO account on first boot (change after first login)
SEED_CEO_PASSWORD=Admin@1234

# Where the SQLite database file is stored (must be a writable, backed-up path)
DATA_DIR=./data
